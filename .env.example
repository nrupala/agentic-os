# OMEGA-CODE Environment Configuration
# Copy this file to .env and configure your settings

# =============================================================================
# PROJECT SETTINGS
# =============================================================================
PROJECT_NAME=default
GOAL=Build a self-healing microservice with health checks.
MAX_ATTEMPTS=50

# =============================================================================
# LLM CONFIGURATION (Choose one provider)
# =============================================================================

# Option 1: OpenAI
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-key-here
# LLM_MODEL=gpt-4

# Option 2: Anthropic
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-your-key-here
# LLM_MODEL=claude-3-sonnet

# Option 3: LM Studio (Local GGUF models) - DEFAULT for local
LLM_PROVIDER=lmstudio
LMSTUDIO_MODEL_PATH=C:/Users/HomeUser/.lmstudio/models

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
VAULT_ENABLED=true
ENCRYPTION_KEY_PATH=projects/${PROJECT_NAME}/state/master.key

# =============================================================================
# EMAIL ALERTING (Optional)
# =============================================================================
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM=omega@localhost
ALERT_TO=admin@example.com

# =============================================================================
# OBSERVABILITY
# =============================================================================
LOKI_URL=http://loki:3100
GRAFANA_URL=http://grafana:3000
GRAFANA_USER=omega
GRAFANA_PASSWORD=omega-secure-123

# =============================================================================
# DOCKER SETTINGS
# =============================================================================
DOCKER_IMAGE=omega-hardened:latest
SANDBOX_IMAGE=python:3.11-slim
RECURSION_LIMIT=50
